<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net10.0;net8.0;net9.0;net11.0</TargetFrameworks>
        <LangVersion>latest</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <PackageId>AlexaVoxCraft.Http</PackageId>
        <Title>AlexaVoxCraft.Http</Title>
        <Description>Shared HTTP infrastructure for AlexaVoxCraft, including access token providers and authentication handlers for typed HttpClient integrations.</Description>
        <PackageTags>alexa;http;authentication;bearer-token;access-token;typed-httpclient;voxcraft;infrastructure</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="LayeredCraft.StructuredLogging"/>
        <PackageReference Include="Microsoft.Extensions.Http"/>
    </ItemGroup>

</Project>
